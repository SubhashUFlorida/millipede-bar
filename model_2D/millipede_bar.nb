CellGroupData[
{Cell[
"\<Convolution integral to get output strain from input strain -- assuming 1D transmission\>",
"Subsubsection",CellChangeTimes -> {{3.972816602007128`*^9,3.972816608627831`*^9},{3.972816679448575`*^9,3.972816693811921`*^9},{3.973057617112444`*^9,3.973057656152886`*^9}},
ExpressionUUID -> "dd84ac10-1e98-4574-9e57-23e513cf48ec"],Cell[
"\<The 1D TF is much easier to handle, we can directly use the time-domain kernel instead of the transfer function, 
and we can do so w/ dimensions (unlike the 2D case that comes dimensionless and has to be carefully 
brought back to physical dimensions).\>",
"Text",CellChangeTimes -> {{3.990673686651016`*^9,3.9906737856222553`*^9}},ExpressionUUID -> "3ee66dbb-5717-472c-aa39-578369c1b622"],Cell[

"\<Everything here has units: both Tch and the the kernel (1/s), and the input (microstrains, i.e., 10**-6)\>",
"Text",CellChangeTimes -> {{3.9728166152859364`*^9,3.972816659139632`*^9},{3.973057196179398`*^9,3.9730572030908957`*^9},{3.990674001512684`*^9,3.9906740259457808`*^9},{3.9906741028328047`*^9,3.990674112453618`*^9}},
ExpressionUUID -> "d6f672a5-6dd8-4696-b7d9-fcfebe09fd3c"],Cell[
BoxData[RowBox[{RowBox[
{"output","[",RowBox[{"t_",",","T_"}],"]"}],":=",RowBox[{"NIntegrate","[",RowBox[
{RowBox[{RowBox[{"-","1."}],"*",FractionBox[RowBox[{"Exp","[",RowBox[{RowBox[{"-","x"}],"/","T"}],"]"}],
"T"],"*",RowBox[{"input","[",RowBox[{"t","-","x"}],"]"}]}],",",RowBox[{"{",RowBox[
{"x",",","0",",","t"}],"}"}]}],"]"}],RowBox[{"(*",RowBox[{"including"," ","-",RowBox[
{"1"," ","because"," ","of"," ",RowBox[{"strain","/","stress"}]," ","sign"," ","flip"," ","not"," ","present"," ","in"," ","displacements"}]}],"*)"}]}]],
